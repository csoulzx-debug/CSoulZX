-- SPEED HUB V4: ULTRA AGGRESSIVE ANTI-LAG (BYPASS KEYWORDS)
local Material = loadstring(game:HttpGet("https://raw.githubusercontent.com/Kinlei/MaterialLua/master/Module.lua"))()

local UI = Material.Load({
    Title = "SPEED HUB V4",
    Style = 3,
    Size = UDim2.fromOffset(400, 280),
    TextColor = Color3.fromRGB(255, 255, 255)
})

local MainTab = UI.New({
    Title = "Main"
})

local _G = _G or {}
_G.SuperAntiLag = false

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Workspace = game:GetService("Workspace")

-- Fungsi mendeteksi apakah objek aman (Jangan di-hide)
local function isSafeObject(object)
    -- Jangan sembunyikan karakter kita atau karakter player lain
    for _, player in pairs(Players:GetPlayers()) do
        if player.Character and object:IsDescendantOf(player.Character) then
            -- Tetap tampilkan baju/aksesoris player
            return true
        end
    end
    
    -- Jangan sembunyikan peta dasar, langit, atau UI dasar game
    local name = object.Name:lower()
    if name == "baseplate" or name == "terrain" or name == "spawnlocation" or object:IsA("Camera") then
        return true
    end
    
    return false
end

-- Fungsi Eksekusi Transparansi Total
local function applySuperHide()
    for _, desc in pairs(Workspace:GetDescendants()) do
        -- Targetkan semua MeshPart, Part, atau SpecialMesh (bentuk visual tanaman)
        if desc:IsA("BasePart") or desc:IsA("MeshPart") then
            if not isSafeObject(desc) then
                if _G.SuperAntiLag then
                    desc.LocalTransparencyModifier = 1
                    desc.CastShadow = false
                else
                    desc.LocalTransparencyModifier = 0
                    desc.CastShadow = true
                end
            end
        end
    end
end

-- Loop di latar belakang untuk membersihkan tanaman yang baru muncul/tumbuh
task.spawn(function()
    while task.wait(1.5) do -- Scan lebih cepat (1.5 detik)
        if _G.SuperAntiLag then
            pcall(applySuperHide)
        end
    end
end)

-- Toggle Menu di UI
MainTab.Toggle({
    Text = "Super Hide All (Anti-Lag 100%)",
    Callback = function(value)
        _G.SuperAntiLag = value
        pcall(applySuperHide) -- Langsung eksekusi perubahan saat ditekan
    end,
    Enabled = false
})

print("SPEED HUB V4: Super Anti-Lag Mode Berhasil Dimuat!")
