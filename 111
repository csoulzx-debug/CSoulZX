-- MENGGUNAKAN REDFIELD UI LIBRARY (MOBILE OPTIMIZED)
local Material = loadstring(game:HttpGet("https://raw.githubusercontent.com/Kinlei/MaterialLua/master/Module.lua"))()

-- Inisialisasi UI Window
local UI = Material.Load({
    Title = "SPEED HUB V4",
    Style = 3,
    Size = UDim2.fromOffset(400, 280), -- Ukuran pas untuk layar HP
    TextColor = Color3.fromRGB(255, 255, 255)
})

-- Membuat Tab Utama
local MainTab = UI.New({
    Title = "Main"
})

-- Variabel Kontrol
local _G = _G or {}
_G.AntiLagEnabled = false

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Workspace = game:GetService("Workspace")

-- Daftar kata kunci nama objek tanaman/buah orang lain
local TARGET_NAMES = {
    "Tanaman", 
    "Buah",
    "Garden",
    "Plant",
    "Fruit"
}

-- Fungsi memeriksa kepemilikan objek
local function isNotMine(object)
    if LocalPlayer.Character and object:IsDescendantOf(LocalPlayer.Character) then
        return false
    end
    
    for _, name in pairs(TARGET_NAMES) do
        if string.find(object.Name:lower(), name:lower()) or (object.Parent and string.find(object.Parent.Name:lower(), name:lower())) then
            return true
        end
    end
    return false
end

-- Fungsi menyembunyikan atau memunculkan kembali objek
local function updateVisibility()
    for _, desc in pairs(Workspace:GetDescendants()) do
        if desc:IsA("BasePart") or desc:IsA("MeshPart") then
            if isNotMine(desc) then
                if _G.AntiLagEnabled then
                    desc.LocalTransparencyModifier = 1
                    desc.CastShadow = false
                else
                    desc.LocalTransparencyModifier = 0
                    desc.CastShadow = true
                end
            end
        end
    end
end

-- Loop latar belakang yang berjalan jika fitur diaktifkan
task.spawn(function()
    while task.wait(3) do
        if _G.AntiLagEnabled then
            pcall(updateVisibility)
        end
    end
end)

-- Membuat Toggle di dalam UI
MainTab.Toggle({
    Text = "Hide Other Players' Garden (Anti-Lag)",
    Callback = function(value)
        _G.AntiLagEnabled = value
        pcall(updateVisibility) -- Langsung eksekusi perubahan saat tombol ditekan
    end,
    Enabled = false
})

print("SPEED HUB V4: Redfield UI berhasil dimuat!")
