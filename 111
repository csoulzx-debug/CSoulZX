local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "SPEED HUB V4 | POSITION LOCK",
   LoadingTitle = "Loading Auto Trade System...",
   LoadingSubtitle = "by Developer",
   ConfigurationSaving = { Enabled = false },
   KeySystem = false
})

local SelectedMutation = "Bacon"
local AutoTradeEnabled = false

-- Daftar semua mutasi yang akan dideteksi jika opsi "Semua Mutasi" dipilih
local MutationList = {
   "Bacon", "Rainbow", "Astral", "Phantom", 
   "Plasma", "Radioactive", "Void", "Shadow", 
   "Electrified", "Virus", "Wet", "Alien", "Enchanted"
}

-- Tabel memori agar tidak mengklik tombol yang SAMA persis berkali-kali
local ClickedSlots = {}

local TradeTab = Window:CreateTab("Trading", 4483362458)
TradeTab:CreateSection("Mutation Filter Settings")

-- Dropdown Pilih Mutasi (Sudah ditambahkan opsi "Semua Mutasi")
local MutationDropdown = TradeTab:CreateDropdown({
   Name = "Pilih Mutasi",
   Options = {
      "Semua Mutasi", "Bacon", "Rainbow", "Astral", "Phantom", 
      "Plasma", "Radioactive", "Void", "Shadow", 
      "Electrified", "Virus", "Wet", "Alien", "Enchanted"
   },
   CurrentOption = {"Bacon"},
   MultipleOptions = false,
   Callback = function(Option)
      SelectedMutation = Option[1]
      ClickedSlots = {} -- Reset memori saat ganti mutasi agar bisa memproses jenis baru
   end,
})

-- Label Status
local StatusLabel = TradeTab:CreateLabel("Status: Auto Trade Mati")

-- Toggle Auto Trade
local TradeToggle = TradeTab:CreateToggle({
   Name = "Auto Trade",
   CurrentValue = false,
   Flag = "AutoTradeToggle",
   Callback = function(Value)
      AutoTradeEnabled = Value
      if not Value then
         StatusLabel:Set("Status: Auto Trade Mati")
         ClickedSlots = {} -- Reset saat dimatikan
      end
   end,
})

-- --- LOGIKA UTAMA: ENDLESS CONTINUOUS SCANNING WITH "SEMUA MUTASI" OPTION ---
local LocalPlayer = game.Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

task.spawn(function()
    while true do
        task.wait(0.25) -- Scan konstan dan cepat setiap 0.25 detik tanpa henti
        
        if AutoTradeEnabled then
            StatusLabel:Set("Status: Memindai " .. SelectedMutation .. "...")
            local foundItem = false
            
            -- PENGAMAN ANTI-UNSELECT: Bersihkan tombol dari memori jika posisinya sudah naik ke atas (posY <= 200)
            for button, _ in pairs(ClickedSlots) do
                if button and button.Parent then
                    if button.AbsolutePosition.Y <= 200 then
                        ClickedSlots[button] = nil
                    end
                else
                    ClickedSlots[button] = nil
                end
            end
            
            for _, gui in ipairs(PlayerGui:GetChildren()) do
                if gui:IsA("ScreenGui") and gui.Enabled and gui.Name ~= "Rayfield" then
                    
                    for _, object in ipairs(gui:GetDescendants()) do
                        if object:IsA("TextLabel") and object.Visible then
                            
                            local textLower = string.lower(object.Text)
                            local isTargetMutation = false
                            
                            -- LOGIKA BARU: Cek filter berdasarkan pilihan Dropdown
                            if SelectedMutation == "Semua Mutasi" then
                                -- Jika memilih "Semua Mutasi", scan semua nama yang ada di daftar tabel MutationList
                                for _, mutationName in ipairs(MutationList) do
                                    if string.find(textLower, string.lower(mutationName)) then
                                        isTargetMutation = true
                                        break
                                    end
                                end
                            else
                                -- Jika memilih mutasi spesifik (misal: Bacon saja), hanya scan nama tersebut
                                if string.find(textLower, string.lower(SelectedMutation)) then
                                    isTargetMutation = true
                                end
                            end
                            
                            -- Eksekusi jika item mutasi yang dicari cocok
                            if isTargetMutation then
                                -- Cari tombol slot itemnya
                                local current = object
                                local clickButton = nil
                                
                                for i = 1, 3 do
                                    if current then
                                        if current:IsA("TextButton") or current:IsA("ImageButton") then
                                            clickButton = current
                                            break
                                        end
                                        clickButton = current:FindFirstChildOfClass("TextButton") or current:FindFirstChildOfClass("ImageButton")
                                        if clickButton then break end
                                        current = current.Parent
                                    end
                                end
                                
                                -- Jalankan klik jika tombol ditemukan dan belum masuk daftar penawaran atas
                                if clickButton and not ClickedSlots[clickButton] then
                                    local posY = clickButton.AbsolutePosition.Y
                                    
                                    -- Kunci area inventory bawah agar item di slot atas tidak ter-unselect (posY > 200)
                                    if posY > 200 then 
                                        foundItem = true
                                        StatusLabel:Set("Status: Mengklik " .. object.Text)
                                        
                                        ClickedSlots[clickButton] = true
                                        
                                        pcall(function()
                                            firesignal(clickButton.MouseButton1Click)
                                            firesignal(clickButton.MouseButton1Down)
                                            firesignal(clickButton.Activated)
                                        end)
                                        
                                        task.wait(0.1) -- Jeda mikro antar item agar proses memasukkan trade lancar
                                    end
                                end
                            end
                            
                        end
                    end
                    
                end
            end
            
            -- Jika semua target mutasi saat ini sudah masuk ke slot atas, script tetap siaga memantau layar
            if not foundItem then
                StatusLabel:Set("Status: Selalu Memantau / Menunggu Item " .. SelectedMutation .. " Baru...")
            end
        end
    end
end)
