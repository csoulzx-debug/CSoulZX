local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "SPEED HUB V4 | POSITION LOCK",
   LoadingTitle = "Loading Auto Trade System...",
   LoadingSubtitle = "by Developer",
   ConfigurationSaving = { Enabled = false },
   KeySystem = false
})

-- Menyimpan daftar mutasi yang sedang dipilih/dicentang oleh user
local SelectedMutations = { ["Bacon"] = true } 
local AutoTradeEnabled = false

-- Tabel memori agar tidak mengklik tombol yang SAMA persis berkali-kali
local ClickedSlots = {}

local TradeTab = Window:CreateTab("Trading", 4483362458)
TradeTab:CreateSection("Mutation Filter Settings")

-- Dropdown diubah menjadi MultipleOptions = true agar bisa memilih banyak mutasi sekaligus
local MutationDropdown = TradeTab:CreateDropdown({
   Name = "Pilih Mutasi (Bisa Pilih Banyak)",
   Options = {
      "None", "Bacon", "Golden", "Diamond", "Molten", 
      "Rainbow", "Astral", "Phantom", "Plasma", "Radioactive", 
      "Void", "Shadow", "Electrified", "Virus", "Wet", "Alien", "Enchanted"
   },
   CurrentOption = {"Bacon"}, 
   MultipleOptions = true, -- Mengaktifkan fitur multi-select asli Rayfield
   Callback = function(Options)
      -- Reset tabel pilihan lama dan memori klik setiap ada perubahan centang
      SelectedMutations = {}
      ClickedSlots = {}
      
      -- Masukkan semua mutasi yang sedang dicentang ke dalam daftar aktif
      for _, optionName in ipairs(Options) do
         SelectedMutations[optionName] = true
      end
   end,
})

-- Label Status
local StatusLabel = TradeTab:CreateLabel("Status: Auto Trade Mati")

-- Toggle Auto Trade
local TradeToggle = TradeTab:CreateToggle({
   Name = "Auto Trade",
   CurrentValue = false,
   Flag = "AutoTradeToggle",
   Callback = function(Value)
      AutoTradeEnabled = Value
      if not Value then
         StatusLabel:Set("Status: Auto Trade Mati")
         ClickedSlots = {} -- Reset saat dimatikan
      end
   end,
})

-- --- LOGIKA UTAMA (DASAR TETAP SAMA): LOCK POSISI LAYAR BAWAH + MULTI FILTER ---
local LocalPlayer = game.Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

task.spawn(function()
    while task.wait(0.3) do
        if AutoTradeEnabled then
            StatusLabel:Set("Status: Memindai Mutasi yang Dipilih...")
            local foundItem = false
            
            -- PENGAMAN ANTI-STUCK: Hapus dari memori jika item sudah berhasil naik ke atas (posY <= 200)
            for button, _ in pairs(ClickedSlots) do
                if button and button.Parent then
                    if button.AbsolutePosition.Y <= 200 then
                        ClickedSlots[button] = nil
                    end
                else
                    ClickedSlots[button] = nil
                end
            end
            
            for _, gui in ipairs(PlayerGui:GetChildren()) do
                if gui:IsA("ScreenGui") and gui.Enabled and gui.Name ~= "Rayfield" then
                    
                    for _, object in ipairs(gui:GetDescendants()) do
                        if object:IsA("TextLabel") and object.Visible then
                            
                            local isTarget = false
                            local textLower = string.lower(object.Text)
                            
                            -- MENCARI APAKAH TEKS COCOK DENGAN SALAH SATU MUTASI YANG DICENTANG
                            for mutationName, active in pairs(SelectedMutations) do
                                if active and string.find(textLower, string.lower(mutationName)) then
                                    isTarget = true
                                    break -- Keluar loop kecil jika sudah ketemu yang cocok
                                end
                            end
                            
                            if isTarget then
                                -- Cari tombol slot itemnya (Logika asli bawaan kamu)
                                local current = object
                                local clickButton = nil
                                
                                for i = 1, 3 do
                                    if current then
                                        if current:IsA("TextButton") or current:IsA("ImageButton") then
                                            clickButton = current
                                            break
                                        end
                                        clickButton = current:FindFirstChildOfClass("TextButton") or current:FindFirstChildOfClass("ImageButton")
                                        if clickButton then break end
                                        current = current.Parent
                                    end
                                end
                                
                                -- Eksekusi jika tombol ketemu dan belum pernah diklik di sesi ini
                                if clickButton and not ClickedSlots[clickButton] then
                                    
                                    -- DETEKSI POSISI (AbsolutePosition.Y)
                                    local posY = clickButton.AbsolutePosition.Y
                                    
                                    if posY > 200 then 
                                        foundItem = true
                                        StatusLabel:Set("Status: Mengklik " .. object.Text)
                                        
                                        -- Catat tombol ini agar tidak disentuh lagi selama masih di bawah
                                        ClickedSlots[clickButton] = true
                                        
                                        -- Jalankan klik secara cepat lewat task.spawn
                                        task.spawn(function()
                                            pcall(function()
                                                firesignal(clickButton.MouseButton1Click)
                                                firesignal(clickButton.MouseButton1Down)
                                                firesignal(clickButton.Activated)
                                            end)
                                        end)
                                    end
                                end
                                
                            end
                        end
                    end
                    
                end
            end
            
            if not foundItem then
                StatusLabel:Set("Status: Standby / Menunggu item mutasi baru...")
            end
        end
    end
end)
