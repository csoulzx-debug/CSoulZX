local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "SPEED HUB V4 | CONTINUOUS SELECTION",
   LoadingTitle = "Loading Auto Trade System...",
   LoadingSubtitle = "by Developer",
   ConfigurationSaving = { Enabled = false },
   KeySystem = false
})

local SelectedMutation = "Bacon"
local AutoTradeEnabled = false

-- Tabel memori agar tidak mengklik tombol yang SAMA persis berkali-kali
local ClickedSlots = {}

local TradeTab = Window:CreateTab("Trading", 4483362458)
TradeTab:CreateSection("Mutation Filter Settings")

-- Dropdown Pilih Mutasi
local MutationDropdown = TradeTab:CreateDropdown({
   Name = "Pilih Mutasi",
   Options = {
      "Pilih Semua", "Bacon", "Rainbow", "Astral", "Phantom", 
      "Plasma", "Radioactive", "Void", "Shadow", 
      "Electrified", "Virus", "Wet", "Alien", "Enchanted"
   },
   CurrentOption = {"Bacon"},
   MultipleOptions = false,
   Callback = function(Option)
      SelectedMutation = Option[1]
      ClickedSlots = {} -- Reset memori saat ganti mutasi agar bisa memproses jenis baru
   end,
})

-- Label Status
local StatusLabel = TradeTab:CreateLabel("Status: Auto Trade Mati")

-- Toggle Auto Trade
local TradeToggle = TradeTab:CreateToggle({
   Name = "Auto Trade",
   CurrentValue = false,
   Flag = "AutoTradeToggle",
   Callback = function(Value)
      AutoTradeEnabled = Value
      if not Value then
         StatusLabel:Set("Status: Auto Trade Mati")
         ClickedSlots = {} -- Reset saat dimatikan
      end
   end,
})

-- --- LOGIKA UTAMA: NON-STOP CONTINUOUS SELECTION LOOP ---
local LocalPlayer = game.Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

task.spawn(function()
    while true do
        task.wait(0.2) -- Jeda konstan antar putaran scan (dipercepat agar lebih agresif)
        
        if AutoTradeEnabled then
            local foundItem = false
            
            -- PENGAMAN ANTI-UNSELECT: Bersihkan tombol dari memori jika posisinya sudah naik ke atas (posY <= 200)
            for button, _ in pairs(ClickedSlots) do
                if button and button.Parent then
                    if button.AbsolutePosition.Y <= 200 then
                        ClickedSlots[button] = nil
                    end
                else
                    ClickedSlots[button] = nil 
                end
            end
            
            for _, gui in ipairs(PlayerGui:GetChildren()) do
                if gui:IsA("ScreenGui") and gui.Enabled and gui.Name ~= "Rayfield" then
                    
                    for _, object in ipairs(gui:GetDescendants()) do
                        if object:IsA("TextButton") or object:IsA("ImageButton") then
                            
                            local parentName = string.lower(object.Parent and object.Parent.Name or "")
                            local buttonName = string.lower(object.Name)
                            
                            -- BLACKLIST SISTEM: Abaikan tombol cancel/decline/close
                            local isCancelButton = string.find(buttonName, "cancel") or string.find(buttonName, "decline") or 
                                                   string.find(buttonName, "close") or string.find(buttonName, "batal") or
                                                   string.find(parentName, "action") or buttonName == "x"
                            
                            if not isCancelButton then
                                local isTarget = false
                                
                                -- Mode 1: Pilih Semua Item di Inventory Bawah
                                if SelectedMutation == "Pilih Semua" then
                                    if object.Visible and object.AbsolutePosition.Y > 200 then
                                        isTarget = true
                                    end
                                else
                                    -- Mode 2: Cari Mutasi Spesifik Berdasarkan Teks / Nama Objek
                                    local hasText = object:FindFirstChildOfClass("TextLabel")
                                    if hasText and string.find(string.lower(hasText.Text), string.lower(SelectedMutation)) then
                                        isTarget = true
                                    elseif string.find(string.lower(object.Name), string.lower(SelectedMutation)) then
                                        isTarget = true
                                    end
                                end
                                
                                -- Eksekusi Klik beruntun
                                if isTarget and not ClickedSlots[object] then
                                    local posY = object.AbsolutePosition.Y
                                    
                                    if posY > 200 then
                                        foundItem = true
                                        StatusLabel:Set("Status: Mengklik " .. object.Name)
                                        
                                        ClickedSlots[object] = true
                                        
                                        pcall(function()
                                            firesignal(object.MouseButton1Click)
                                            firesignal(object.MouseButton1Down)
                                            firesignal(object.Activated)
                                        end)
                                        
                                        -- Jeda mikro (0.1 detik) antar klik item agar game tidak mendeteksi spam berlebih yang menyebabkan kick,
                                        -- tapi tetap cukup cepat untuk memasukkan seluruh item secara beruntun.
                                        task.wait(0.1) 
                                    end
                                end
                                
                            end
                        end 
                    end
                    
                end
            end
            
            if not foundItem then
                StatusLabel:Set("Status: Standby / Memantau " .. SelectedMutation .. "...")
            end
        end
    end
end)
