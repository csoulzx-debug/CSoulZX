local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "SPEED HUB V4 | POSITION LOCK",
   LoadingTitle = "Loading Auto Trade System...",
   LoadingSubtitle = "by Developer",
   ConfigurationSaving = { Enabled = false },
   KeySystem = false
})

local SelectedMutations = { ["Bacon"] = true }
local AutoTradeEnabled = false

local ClickedSlots = {}

local TradeTab = Window:CreateTab("Trading", 4483362458)
TradeTab:CreateSection("Mutation Filter Settings")

local MutationDropdown = TradeTab:CreateDropdown({
   Name = "Pilih Mutasi",
   Options = {
      "None", "Bacon", "Golden", "Diamond", "Molten", "Volcanic", "Chicleteira", "Trippi", "Agarrini", "Rainbow", "Astral", 
      "Phantom", "Plasma", "Radioactive", "Void", "Shadow", 
      "Electrified", "Virus", "Wet", "Alien", "Enchanted"
   },
   CurrentOption = {"Bacon"},
   MultipleOptions = true,
   Callback = function(Options)
      SelectedMutations = {}
      ClickedSlots = {} 
      
      for _, optionName in ipairs(Options) do
         SelectedMutations[optionName] = true
      end
   end,
})

local StatusLabel = TradeTab:CreateLabel("Status: Auto Trade Mati")

local TradeToggle = TradeTab:CreateToggle({
   Name = "Auto Trade",
   CurrentValue = false,
   Flag = "AutoTradeToggle",
   Callback = function(Value)
      AutoTradeEnabled = Value
      if not Value then
         StatusLabel:Set("Status: Auto Trade Mati")
         ClickedSlots = {} 
      end
   end,
})

-- --- LOGIKA UTAMA: LOCK POSISI LAYAR BAWAH ---
local LocalPlayer = game.Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

task.spawn(function()
    while task.wait(0.4) do
        if AutoTradeEnabled then
            StatusLabel:Set("Status: Memindai Mutasi yang Dipilih...")
            local foundItem = false
            
            for _, gui in ipairs(PlayerGui:GetChildren()) do
                if gui:IsA("ScreenGui") and gui.Enabled then
                    
                    for _, object in ipairs(gui:GetDescendants()) do
                        if (object:IsA("TextLabel") or object:IsA("TextButton") or object:IsA("ImageLabel") or object:IsA("ImageButton")) and object.Visible then
                            
                            local isTarget = false
                            local textContent = ""
                            if object:IsA("TextLabel") or object:IsA("TextButton") then
                                textContent = string.lower(object.Text)
                            end
                            local nameContent = string.lower(object.Name)
                            
                            for mutationName, active in pairs(SelectedMutations) do
                                if active then
                                    local mutLower = string.lower(mutationName)
                                    if string.find(textContent, mutLower) or string.find(nameContent, mutLower) then
                                        isTarget = true
                                        break
                                    end
                                end
                            end
                            
                            if isTarget then
                                -- Memperluas pencarian slot dari 3 menjadi 5 tingkat (Berjaga-jaga UI game lebih dalam)
                                local current = object
                                local clickButton = nil
                                
                                for i = 1, 5 do
                                    if current then
                                        if current:IsA("TextButton") or current:IsA("ImageButton") then
                                            clickButton = current
                                            break
                                        end
                                        clickButton = current:FindFirstChildOfClass("TextButton") or current:FindFirstChildOfClass("ImageButton")
                                        if clickButton then break end
                                        current = current.Parent
                                    end
                                end
                                
                                if clickButton and not ClickedSlots[clickButton] then
                                    local posY = clickButton.AbsolutePosition.Y
                                    
                                    if posY > 200 then 
                                        foundItem = true
                                        StatusLabel:Set("Status: Mengklik Slot!")
                                        
                                        ClickedSlots[clickButton] = true
                                        
                                        -- SISTEM KLIK YANG LEBIH KUAT (Anti Gagal untuk Eksekutor Mobile)
                                        pcall(function()
                                            -- 1. Jalur Sinyal Standar (Ditambah MouseButton1Up)
                                            if firesignal then
                                                firesignal(clickButton.MouseButton1Click)
                                                firesignal(clickButton.MouseButton1Down)
                                                firesignal(clickButton.MouseButton1Up) 
                                                firesignal(clickButton.Activated)
                                            end
                                            
                                            -- 2. Jalur Bypass Langsung ke Fungsi (Sangat Ampuh)
                                            if getconnections then
                                                for _, conn in pairs(getconnections(clickButton.MouseButton1Click)) do
                                                    if conn.Function then conn.Function() end
                                                end
                                                for _, conn in pairs(getconnections(clickButton.Activated)) do
                                                    if conn.Function then conn.Function() end
                                                end
                                            end
                                        end)
                                        
                                        task.wait(0.25)
                                    end
                                end
                            end
                            
                        end
                    end
                    
                end
            end
            
            if not foundItem then
                StatusLabel:Set("Status: Selesai / Tidak ada mutasi baru.")
            end
        end
    end
end)
