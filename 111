-- SPEED HUB V4: TOTAL ANTI-LAG SYSTEM (ALL PLANTS HIDER)
local Material = loadstring(game:HttpGet("https://raw.githubusercontent.com/Kinlei/MaterialLua/master/Module.lua"))()

-- Inisialisasi UI Window
local UI = Material.Load({
    Title = "SPEED HUB V4",
    Style = 3,
    Size = UDim2.fromOffset(400, 280),
    TextColor = Color3.fromRGB(255, 255, 255)
})

local MainTab = UI.New({
    Title = "Main"
})

-- Variabel Kontrol Global
local _G = _G or {}
_G.AntiLagEnabled = false

local Workspace = game:GetService("Workspace")

-- Kamus kata kunci super luas (deteksi model, folder, atau part)
local AGGRESSIVE_KEYWORDS = {
    "tanaman", "buah", "garden", "plant", "fruit", "crop", "seed", 
    "flower", "bunga", "pohon", "tree", "plot", "dirt", "farm",
    "harvest", "berry", "tomato", "carrot", "apple", "wheat",
    "fertilizer", "pot", "planter", "vegetable", "daisy"
}

-- Fungsi deteksi berdasarkan nama objek atau nama induknya
local function checkTarget(object)
    local objName = object.Name:lower()
    for _, keyword in pairs(AGGRESSIVE_KEYWORDS) do
        if string.find(objName, keyword) then
            return true
        end
    end
    
    -- Cek juga nama parent-nya (jika part berada di dalam Model tanaman)
    if object.Parent then
        local parentName = object.Parent.Name:lower()
        for _, keyword in pairs(AGGRESSIVE_KEYWORDS) do
            if string.find(parentName, keyword) then
                return true
            end
        end
    end
    
    return false
end

-- Fungsi eksekutor transparansi
local function updateVisibility()
    for _, desc in pairs(Workspace:GetDescendants()) do
        if desc:IsA("BasePart") or desc:IsA("MeshPart") then
            if checkTarget(desc) then
                if _G.AntiLagEnabled then
                    desc.LocalTransparencyModifier = 1
                    desc.CastShadow = false
                else
                    desc.LocalTransparencyModifier = 0
                    desc.CastShadow = true
                end
            end
        end
    end
end

-- Loop pengecekan dipercepat menjadi 2 detik agar tanaman yang baru tumbuh langsung hilang
task.spawn(function()
    while task.wait(2) do
        if _G.AntiLagEnabled then
            pcall(updateVisibility)
        end
    end
end)

-- Toggle Menu
MainTab.Toggle({
    Text = "Hide ALL Gardens & Plants",
    Callback = function(value)
        _G.AntiLagEnabled = value
        pcall(updateVisibility) -- Langsung eksekusi saat di-klik
    end,
    Enabled = false
})

print("SPEED HUB V4: Fitur Hide All Garden Siap Digunakan!")
